# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEN_API_KEY: Token for GenAPI (https://gen-api.ru) DeepSeek V4 access
GEN_API_KEY=""

# GEN_API_MODEL: The DeepSeek model to use (defaults to deepseek-v4-flash)
GEN_API_MODEL="deepseek-v4-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Database Configuration (Optional, defaults to SQLite dev.db file)
DATABASE_URL="file:./dev.db"

# JWT Secret for secure native user authentication sessions
JWT_SECRET="some-very-secure-secret-key-change-it"

# YOOKASSA PAYMENT CONFIGURATION
YOOKASSA_SHOP_ID="1386669"
YOOKASSA_SECRET_KEY="test__t_kaIemOSA5qOw13N6n9UCJHyHhZFLRJD_KxYrhmBA"


