# Runtime
NODE_ENV="production"
APP_URL="https://decksy.ru"

# Database
DATABASE_URL="postgresql://decksy:CHANGE_ME@localhost:5432/decksy?schema=public"

# AI provider. Configure at least one of GEMINI_API_KEY or GEN_API_KEY in production.
GEMINI_API_KEY=""
GEN_API_KEY=""
GEN_API_MODEL="deepseek-v4-flash"

# JWT Secret for secure native user authentication sessions
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Comma-separated list of emails that should receive admin + Pro access.
ADMIN_EMAILS="admin@example.com"

# Email verification SMTP. Without SMTP, email/password registration is created but cannot be verified automatically.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Decksy Ai <noreply@decksy.ru>"

# OAuth providers. Callback URLs:
# https://decksy.ru/api/auth/oauth/google/callback
# https://decksy.ru/api/auth/oauth/yandex/callback
# https://decksy.ru/api/auth/oauth/vk/callback
# https://decksy.ru/api/auth/oauth/mailru/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""
VK_CLIENT_ID=""
VK_CLIENT_SECRET=""
MAILRU_CLIENT_ID=""
MAILRU_CLIENT_SECRET=""

# YooKassa payment configuration
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
