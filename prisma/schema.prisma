datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  Int         @id @default(autoincrement())
  email               String      @unique
  password            String?
  name                String?
  emailVerified       Boolean     @default(false)
  emailVerifiedAt     DateTime?
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  role                String      @default("user")
  isPro               Boolean     @default(false)
  plan                String      @default("Free")
  planStartedAt       DateTime?
  planExpiresAt       DateTime?
  monthlyDeckCount    Int         @default(0)
  monthlyDeckResetAt  DateTime?
  freeExportUsed      Boolean     @default(false)
  tokenVersion        Int         @default(0)
  createdAt           DateTime    @default(now())
  decks               PitchDeck[]
  yoomoneyAccessToken String?
  payments            Payment[]
  oauthAccounts       OAuthAccount[]
}

model OAuthAccount {
  id                Int      @id @default(autoincrement())
  provider          String
  providerAccountId String
  email             String?
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Payment {
  id        String   @id // YooKassa payment ID
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  tariffId  String
  status    String   // "pending", "succeeded", "canceled"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RequestLog {
  id        Int      @id @default(autoincrement())
  path      String
  method    String
  createdAt DateTime @default(now())
}

model Ad {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  link      String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PitchDeck {
  id         String   @id
  title      String
  subtitle   String?
  idea       String
  mode       String
  slidesJson String
  roastJson  String?
  canvasJson String?
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
